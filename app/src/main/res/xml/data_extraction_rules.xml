<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- 위치 기록과 앞으로 생성할 경로 썸네일은 클라우드 백업에서 제외한다. -->
        <exclude domain="file" path="current_track.csv" />
        <exclude domain="file" path="current_session.txt" />
        <exclude domain="file" path="history/" />
        <exclude domain="file" path="thumbnails/" />
    </cloud-backup>
    <device-transfer>
        <!-- 기기 간 전송에서도 사용자의 이동 기록은 자동 이전하지 않는다. -->
        <exclude domain="file" path="current_track.csv" />
        <exclude domain="file" path="current_session.txt" />
        <exclude domain="file" path="history/" />
        <exclude domain="file" path="thumbnails/" />
    </device-transfer>
</data-extraction-rules>
